# Swiss Road & Mobility MCP — environment template (ARCH-005)
# Copy to `.env` and fill in. `.env` is git-ignored; never commit real keys.

# Phase 2 (traffic situations / counters) — free key from
# https://api-manager.opentransportdata.swiss
# Leave unset to disable Phase-2 tools.
OPENTRANSPORTDATA_API_KEY=replace-with-free-key

# Transport: stdio (default, local) | sse (cloud)
# MCP_TRANSPORT=stdio

# SSE only — default host is 127.0.0.1 (localhost). Set 0.0.0.0 ONLY inside a
# container/cloud runtime (see SEC-016).
# MCP_HOST=127.0.0.1
# MCP_PORT=8001

# SSE only — allowed CORS origins (comma-separated) for browser MCP clients
# (SDK-004). Unset = wildcard "*".
# ALLOWED_ORIGINS=https://claude.ai,https://app.example.ch

# SSE only — SEC-009 hardening.
# MCP_AUTH_TOKEN: shared secret. When set, every SSE request must send
#   "Authorization: Bearer <token>". When UNSET the endpoint is
#   unauthenticated (the server logs a loud warning). Strongly recommended
#   for any public SSE deployment.
# MCP_AUTH_TOKEN=generate-a-long-random-token
# MCP_RATE_LIMIT: max requests per IP per window (default 60; 0 disables).
# MCP_RATE_WINDOW: window length in seconds (default 60).
# MCP_RATE_LIMIT=60
# MCP_RATE_WINDOW=60
